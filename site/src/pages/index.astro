---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const categoryLabels: Record<string, string> = {
  devlog: 'Dev Log',
  'body-mind': 'Body & Mind',
  culture: 'Culture',
  essays: 'Essays',
  projects: 'Projects',
};
---

<Base>
  <section class="hero">
    <h1>SlothfulDevLog</h1>
    <p class="tagline">学び・実験・発見の記録。<br />力まず、自分のペースで。</p>
  </section>

  {posts.length > 0 && (
    <section class="recent">
      <h2>Recent</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}`}>
              <span class="post-category">{categoryLabels[post.data.category] ?? post.data.category}</span>
              <span class="post-title">{post.data.title}</span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
      <a href="/posts" class="see-all">All articles &rarr;</a>
    </section>
  )}

  <style>
    .hero {
      padding: var(--space-xl) 0;
    }

    .hero h1 {
      font-size: 2.8rem;
      margin-bottom: var(--space-xs);
    }

    .tagline {
      color: var(--color-muted);
      font-size: 1.1rem;
    }

    .recent h2 {
      margin-top: 0;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-muted);
      font-family: var(--font-body);
      font-weight: 600;
    }

    .post-list {
      list-style: none;
      padding: 0;
    }

    .post-list li {
      border-bottom: 1px solid var(--color-border);
    }

    .post-list a {
      display: flex;
      align-items: baseline;
      gap: var(--space-sm);
      padding: var(--space-sm) 0;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .post-list a:hover {
      opacity: 0.7;
    }

    .post-category {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-accent);
      flex-shrink: 0;
      min-width: 6rem;
    }

    .post-title {
      flex: 1;
    }

    time {
      font-size: 0.8rem;
      color: var(--color-muted);
      flex-shrink: 0;
    }

    .see-all {
      display: inline-block;
      margin-top: var(--space-sm);
      font-size: 0.9rem;
      color: var(--color-muted);
      text-decoration: none;
    }

    .see-all:hover {
      color: var(--color-text);
    }

    @media (max-width: 600px) {
      .hero h1 {
        font-size: 2rem;
      }

      .post-list a {
        flex-wrap: wrap;
      }

      .post-category {
        min-width: auto;
      }

      time {
        width: 100%;
      }
    }
  </style>
</Base>
