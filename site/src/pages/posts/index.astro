---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  devlog: 'Dev Log',
  'body-mind': 'Body & Mind',
  culture: 'Culture',
  essays: 'Essays',
  projects: 'Projects',
};

const categories = Object.keys(categoryLabels);
---

<Base title="Articles" description="SlothfulDevLogのすべての記事">
  <h1>Articles</h1>

  <div class="filters">
    <a href="/posts" class="filter-tag active">All</a>
    {categories.map(cat => (
      <a href={`/posts?category=${cat}`} class="filter-tag">{categoryLabels[cat]}</a>
    ))}
  </div>

  <ul class="post-list">
    {allPosts.map((post) => (
      <li>
        <a href={`/posts/${post.id}`} class="post-item">
          <div class="post-meta">
            <span class="post-category">{categoryLabels[post.data.category] ?? post.data.category}</span>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          {post.data.description && (
            <p class="post-desc">{post.data.description}</p>
          )}
        </a>
      </li>
    ))}
  </ul>

  {allPosts.length === 0 && (
    <p class="empty">記事はまだありません。</p>
  )}

  <style>
    h1 {
      margin-bottom: var(--space-md);
    }

    .filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      margin-bottom: var(--space-lg);
    }

    .filter-tag {
      font-size: 0.8rem;
      padding: 0.3em 0.9em;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      text-decoration: none;
      color: var(--color-muted);
      transition: all 0.2s;
    }

    .filter-tag:hover,
    .filter-tag.active {
      border-color: var(--color-text);
      color: var(--color-text);
    }

    .post-list {
      list-style: none;
      padding: 0;
    }

    .post-item {
      display: block;
      padding: var(--space-md) 0;
      border-bottom: 1px solid var(--color-border);
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .post-item:hover {
      opacity: 0.7;
    }

    .post-meta {
      display: flex;
      gap: var(--space-sm);
      align-items: center;
      margin-bottom: var(--space-xs);
    }

    .post-category {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-accent);
    }

    time {
      font-size: 0.8rem;
      color: var(--color-muted);
    }

    .post-title {
      font-size: 1.3rem;
      margin: 0 0 var(--space-xs);
    }

    .post-desc {
      font-size: 0.95rem;
      color: var(--color-muted);
      margin: 0;
      line-height: 1.5;
    }

    .empty {
      color: var(--color-muted);
      padding: var(--space-lg) 0;
    }
  </style>
</Base>
